# Supabase cloud sync (optional — the app runs local-first without these).
# Copy to .env.local and fill in. The anon/publishable key is safe to expose in
# the client; Row Level Security protects the data. Never put the service-role key here.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx
